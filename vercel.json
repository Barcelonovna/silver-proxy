{
  "version": 2,
  "functions": {
    "api/query.js": { "maxDuration": 15 },
    "api/sheets.js": { "maxDuration": 10 }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/trends", "dest": "/public/trends.html" },
    { "src": "/trends.html", "dest": "/public/trends.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}